	file = {PDF:/Users/yannikpoth/Zotero/storage/DLBNMLJE/Beauducel et al. - 2003 - Psychometrische Eigenschaften und Normen einer deutschsprachigen Fassung der Sensation Seeking-Skale.pdf:application/pdf},
