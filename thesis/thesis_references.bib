@misc{poth_salient_2025,
	title = {Salient cues influence learning rate in reinforcement learning},
	rights = {Creative Commons Attribution Non Commercial No Derivatives 4.0 International},
	url = {https://osf.io/cx7kr/},
	doi = {10.17605/OSF.IO/CX7KR},
	abstract = {This study investigates how win-paired salient audiovisual feedback influences learning rates in a reinforcement learning framework. Using a restless two-armed bandit task, participants will make decisions under conditions where salient cues (i.e., prominent audiovisual stimuli) are systematically paired with rewards, following a variable reinforcement pattern. The use of salient cues is inspired by their application in electronic gambling machines, such as online slot machines, where they are known to amplify reward-related signals and potentially distort learning processes. By simulating these conditions in a controlled experimental setting, the study investigates how such feedback might skew adaptive decision-making and modulate participants' learning rates, as quantified by a reinforcement learning model incorporating an alpha shift parameter (i.e. a modulation term capturing the difference in learning rates between trials with and without salient feedback). Additionally, the study examines interindividual differences in the impact of salient cues, considering factors like sensation seeking and impulsivity. Furthermore, the salient cues’ influence on participants’ win-stay behavior (the probability of choosing the same option on the next trial if it resulted in a win in the previous one) and post-reinforcement-pauses ({PRPs}) will be examined. Through this design, we seek to deepen the understanding of how environmental factors shape learning and decision-making processes, as well as reward evaluation in both adaptive and potentially maladaptive contexts.},
	publisher = {{OSF} Registries},
	author = {Poth, Yannik and Peters, Jan and Hopf, Julia Sophie},
	editora = {{Center For Open Science}},
	editoratype = {collaborator},
	urldate = {2025-05-15},
	date = {2025},
	keywords = {Biological Psychology, Cognitive Psychology, Experimental Analysis of Behavior, {FOS}: Psychology, Psychology, Social and Behavioral Sciences},
}

